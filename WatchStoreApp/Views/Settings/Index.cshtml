@model WatchStoreApp.Models.Setting

@{
    ViewData["Title"] = "Settings";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var themeBg = "bg-[#005844]";
    var themeHoverBg = "hover:bg-[#004535]";
}

<div class="max-w-5xl mx-auto p-8 font-sans">
    <h1 class="text-2xl font-bold text-gray-800 uppercase tracking-wide mb-10">SETTINGS</h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 rounded-md bg-green-50 p-4 border border-green-200">
            <div class="flex">
                <div class="flex-shrink-0">
                    <i class="bi bi-check-circle-fill text-green-500"></i>
                </div>
                <div class="ml-3">
                    <p class="text-sm font-medium text-green-800">@TempData["SuccessMessage"]</p>
                </div>
            </div>
        </div>
    }

    <form asp-action="Index" method="post" class="mb-10">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="SettingId" />

        <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
            <div class="flex items-center gap-6">
                <label asp-for="ShippingFee" class="text-lg font-bold text-gray-800 whitespace-nowrap">
                    Shipping Fee
                </label>
                <div class="flex-1 relative rounded-md shadow-sm max-w-md">
                    <input asp-for="ShippingFee"
                           type="number"
                           step="1000"
                           min="0"
                           class="block w-full rounded-md border-gray-300 pr-12 py-3 focus:border-[color:var(--theme)] focus:ring-[color:var(--theme)] sm:text-lg"
                           style="--theme:#005844"
                           placeholder="Shipping Fee (VND)" />
                    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                        <span class="text-gray-400 sm:text-lg">VND</span>
                    </div>
                </div>
                <button type="submit"
                        name="section" value="shipping"
                        class="px-8 py-3 @themeBg text-white text-lg font-medium rounded-md shadow-sm hover:@themeHoverBg focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[color:var(--theme)] transition-all"
                        style="--theme:#005844">
                    Update Fee
                </button>
            </div>
            <span asp-validation-for="ShippingFee" class="text-sm text-red-600 mt-2 block"></span>
        </div>
    </form>

    <form asp-action="Index" method="post" enctype="multipart/form-data" class="space-y-10">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="SettingId" />
        <input type="hidden" asp-for="ShippingFee" />

        <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

                <div class="space-y-4">
                    <label asp-for="Banner1_1" class="block text-lg font-bold text-gray-800">Banner 1.1</label>
                    <div class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center bg-gray-50">
                        <p class="text-gray-500 mb-4">Choose image</p>
                        <input type="file"
                               name="Banner1_1"
                               class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4
                                  file:rounded-full file:border-0 file:text-sm file:font-semibold
                                  file:bg-[color:var(--theme)] file:text-white hover:file:bg-opacity-90"
                               style="--theme:#005844" />
                    </div>
                    <button type="submit"
                            name="section"
                            value="banner1_1"
                            class="w-full px-6 py-3 @themeBg text-white text-lg font-medium rounded-md shadow-sm hover:@themeHoverBg transition-all">
                        Update
                    </button>

                </div>

                <div class="space-y-4">
                    <label asp-for="Banner1_2" class="block text-lg font-bold text-gray-800">Banner 1.2</label>
                    <div class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center bg-gray-50">
                        <p class="text-gray-500 mb-4">Choose image</p>
                        <input type="file"
                               name="Banner1_2"
                               accept="image/*"
                               class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4
                                  file:rounded-full file:border-0 file:text-sm file:font-semibold
                                  file:bg-[color:var(--theme)] file:text-white hover:file:bg-opacity-90"
                               style="--theme:#005844" />
                    </div>
                    <button type="submit"
                            name="section"
                            value="banner1_2"
                            class="w-full px-6 py-3 @themeBg text-white text-lg font-medium rounded-md shadow-sm hover:@themeHoverBg transition-all">
                        Update
                    </button>

                </div>

                <div class="space-y-4">
                    <label asp-for="Banner1_3" class="block text-lg font-bold text-gray-800">Banner 1.3</label>
                    <div class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center bg-gray-50">
                        <p class="text-gray-500 mb-4">Choose image</p>
                        <input type="file"
                               name="Banner1_3"
                               class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4
                                  file:rounded-full file:border-0 file:text-sm file:font-semibold
                                  file:bg-[color:var(--theme)] file:text-white hover:file:bg-opacity-90"
                               style="--theme:#005844" />
                    </div>
                    <button type="submit"
                            name="section"
                            value="banner1_3"
                            class="w-full px-6 py-3 @themeBg text-white text-lg font-medium rounded-md shadow-sm hover:@themeHoverBg transition-all">
                        Update
                    </button>

                </div>

                <div class="space-y-4">
                    <label asp-for="Banner2" class="block text-lg font-bold text-gray-800">Banner 2</label>
                    <div class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center bg-gray-50">
                        <p class="text-gray-500 mb-4">Choose image</p>
                        <input type="file"
                               name="Banner2"
                               class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4
                                  file:rounded-full file:border-0 file:text-sm file:font-semibold
                                  file:bg-[color:var(--theme)] file:text-white hover:file:bg-opacity-90"
                               style="--theme:#005844" />
                    </div>
                    <button type="submit"
                            name="section"
                            value="banner2"
                            class="w-full px-6 py-3 @themeBg text-white text-lg font-medium rounded-md shadow-sm hover:@themeHoverBg transition-all">
                        Update
                    </button>

                </div>

                <div class="space-y-4">
                    <label asp-for="Banner3" class="block text-lg font-bold text-gray-800">Banner 3</label>
                    <div class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center bg-gray-50">
                        <p class="text-gray-500 mb-4">Choose image</p>
                        <input type="file"
                               name="Banner3"
                               class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4
                                  file:rounded-full file:border-0 file:text-sm file:font-semibold
                                  file:bg-[color:var(--theme)] file:text-white hover:file:bg-opacity-90"
                               style="--theme:#005844" />
                    </div>
                    <button type="submit"
                            name="section"
                            value="banner3"
                            class="w-full px-6 py-3 @themeBg text-white text-lg font-medium rounded-md shadow-sm hover:@themeHoverBg transition-all">
                        Update
                    </button>

                </div>

                <div class="space-y-4">
                    <label asp-for="Banner4" class="block text-lg font-bold text-gray-800">Banner 4</label>
                    <div class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center bg-gray-50">
                        <p class="text-gray-500 mb-4">Choose image</p>
                        <input type="file"
                               name="Banner4"
                               class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4
                                  file:rounded-full file:border-0 file:text-sm file:font-semibold
                                  file:bg-[color:var(--theme)] file:text-white hover:file:bg-opacity-90"
                               style="--theme:#005844" />
                    </div>
                    <button type="submit"
                            name="section"
                            value="banner4"
                            class="w-full px-6 py-3 @themeBg text-white text-lg font-medium rounded-md shadow-sm hover:@themeHoverBg transition-all">
                        Update
                    </button>

                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}