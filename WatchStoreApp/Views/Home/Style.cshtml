@model IEnumerable<WatchStoreApp.Models.Product>

@{
    ViewData["Title"] = "Watch Style";
}

<div class="max-w-7xl mx-auto p-6 font-sans">

    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-600 mb-4">
        <a href="/Home" class="text-blue-500 hover:underline">Home</a>
        <span> / </span>
        <span class="font-medium">@ViewBag.Type</span>
    </nav>

    <!-- Title -->
    <h1 class="text-2xl font-bold uppercase mb-6 text-gray-800">@ViewBag.Type Watches</h1>

    <!-- Products List -->
    @if (Model != null && Model.Any())
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            @foreach (var p in Model)
            {
                var specs = $"{p.CaseDiameter}mm | {p.WatchType}";
                var imageUrl = string.IsNullOrEmpty(p.ImageUrl1) ? "https://images.unsplash.com/photo-1523170335258-f5ed11844a49?auto=format&fit=crop&q=80&w=600" : p.ImageUrl1;
                var price = p.SellingPrice.ToString("N0") + "₫";
                
                <div class="bg-white p-4 rounded-lg shadow-sm hover:shadow-xl transition-shadow duration-300 group text-center border border-transparent hover:border-gray-100">
                    <a href="@(p.WatchType == "Smartwatch" ? $"/Home/Smartwatch/{p.ProductId}" : $"/Home/Mechanical/{p.ProductId}")" class="block">
                        <div class="w-full h-64 flex items-center justify-center mb-4 overflow-hidden">
                            <img src="@imageUrl" alt="@p.Name" class="max-h-full max-w-full object-contain group-hover:scale-110 transition-transform duration-500" onerror="this.src='https://images.unsplash.com/photo-1523170335258-f5ed11844a49?auto=format&fit=crop&q=80&w=600'">
                        </div>
                    </a>

                    <h4 class="text-sm font-semibold text-gray-800 mb-1 leading-snug min-h-[40px] line-clamp-2">
                        @p.Name
                    </h4>

                    <p class="text-xs text-gray-500 mb-3">@specs</p>

                    <p class="text-lg font-bold text-[#005844] mb-4">@price</p>

                    <a href="@(p.WatchType == "Smartwatch" ? $"/Home/Smartwatch/{p.ProductId}" : $"/Home/Mechanical/{p.ProductId}")" 
                       class="w-full py-2 text-white rounded font-medium transition-colors shadow-sm block text-center"
                       style="background-color: #005844;"
                       onmouseover="this.style.backgroundColor='#004535'"
                       onmouseout="this.style.backgroundColor='#005844'">
                        Add to Cart
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center text-gray-500 py-16">
            <h5 class="text-lg">No products found for "@ViewBag.Type".</h5>
        </div>
    }
</div>
