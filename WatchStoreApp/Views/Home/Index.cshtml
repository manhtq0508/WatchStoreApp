            <div id="hero-carousel" class="md:col-span-2 rounded-xl overflow-hidden shadow-sm relative h-64 md:h-[500px] group">
                <div class="relative h-full w-full">
                    <div class="carousel-item absolute inset-0 w-full h-full transition-opacity duration-700 ease-in-out opacity-100" data-index="0">
                        <img src="@banner1_1" class="w-full h-full object-cover" alt="Banner 1">
                    </div>
