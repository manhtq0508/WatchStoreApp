        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            @if (ViewBag.TopSellingProducts != null)
            {
                foreach (Product product in ViewBag.TopSellingProducts)
                {
                    var specs = $"{product.CaseDiameter}mm | {product.WatchType}";
                    var imageUrl = string.IsNullOrEmpty(product.ImageUrl1) ? "https://images.unsplash.com/photo-1523170335258-f5ed11844a49?auto=format&fit=crop&q=80&w=600" : product.ImageUrl1;
                    var price = product.SellingPrice.ToString("N0") + "₫";
                    
