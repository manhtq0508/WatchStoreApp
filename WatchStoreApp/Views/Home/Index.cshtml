@using WatchStoreApp.Models
@{
    ViewData["Title"] = "Home Page";

    // Theme colors
    var themeColorBg = "bg-[#005844]";
    var themeColorText = "text-[#005844]";

    // --- NEW: BANNER LOGIC ---
    var settings = ViewBag.Settings as Setting;

    // Helper function to get DB image or Default image
    string GetBanner(string? dbPath, string defaultPath)
    {
        return !string.IsNullOrEmpty(dbPath) ? dbPath : defaultPath;
    }

    var banner1_1 = GetBanner(settings?.Banner1_1, "/images/banner/image1_1.jpg"); 
    var banner1_2 = GetBanner(settings?.Banner1_2, "/images/banner/banner1_2.png"); 
    var banner1_3 = GetBanner(settings?.Banner1_3, "/images/banner/banner1_3.jpg"); 
    var banner2 = GetBanner(settings?.Banner2, "/images/banner/banner2.png"); 
    var banner3 = GetBanner(settings?.Banner3, "/images/banner/banner3.jpg");
    var banner4 = GetBanner(settings?.Banner4, "/images/banner/banner4.jpg"); 
}

<div class="w-full bg-white py-4 font-sans border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        @{
            var tabStyle = "tab-btn inline-flex items-center gap-2 py-3 px-6 text-gray-600 font-medium text-sm uppercase tracking-wide border-b-2 border-transparent hover:text-[#005844] hover:border-[#005844] transition duration-300 focus:outline-none no-underline";
        }
        <nav class="flex flex-wrap justify-center gap-4 overflow-x-auto hide-scrollbar">
             <a href="/Home/Brands" class="@tabStyle"><i class="bi bi-watch"></i> Brands</a>
            <a href="/Home/Mechanical" class="@tabStyle"><i class="bi bi-gear-wide-connected"></i> Mechanical Watches</a>
            <a href="/Home/Smartwatch" class="@tabStyle"><i class="bi bi-smartwatch"></i> Smart Watches</a>
            <button onclick="openFragment(event, 'gender')" class="@tabStyle"><i class="bi bi-gender-ambiguous"></i> Gender</button>
            <button onclick="openFragment(event, 'style')" class="@tabStyle"><i class="bi bi-palette"></i> Styles</button>
        </nav>

        <div class="min-h-[10px]">
            <div id="gender" class="fragment-content hidden fade-in text-center py-4">
                <div class="flex flex-wrap gap-3 justify-center">
                    @if (ViewBag.Genders != null)
                    {
                        foreach (var gender in ViewBag.Genders)
                        {
                            <a class="px-5 py-2 bg-gray-50 text-gray-700 rounded-full hover:bg-[#005844] hover:text-white transition text-sm" href="/Home/Gender?gender=@gender">@gender</a>
                        }
                    }
                </div>
            </div>
            <div id="style" class="fragment-content hidden fade-in text-center py-4">
                <div class="flex flex-wrap gap-3 justify-center">
                    @if (ViewBag.Styles != null)
                    {
                        foreach (var style in ViewBag.Styles)
                        {
                            <a class="px-5 py-2 bg-gray-50 text-gray-700 rounded-full hover:bg-[#005844] hover:text-white transition text-sm" href="/Home/Style?style=@style">@style</a>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="w-full bg-white py-6">
