<script>
    function openFragment(evt, fragmentName) {
        const fragments = document.getElementsByClassName("fragment-content");
        for (let i = 0; i < fragments.length; i++) fragments[i].classList.add("hidden");
        document.getElementById(fragmentName).classList.remove("hidden");
    }

    document.addEventListener('DOMContentLoaded', function() {
        // Simple auto-carousel script
        const items = document.querySelectorAll('.carousel-item');
        let currentItem = 0;
        let slideInterval;

        function showSlide(index) {
            if (index >= items.length) index = 0;
            if (index < 0) index = items.length - 1;
            items.forEach((item, i) => {
                if (i === index) { item.classList.remove('opacity-0'); item.classList.add('opacity-100', 'z-10'); }
                else { item.classList.remove('opacity-100', 'z-10'); item.classList.add('opacity-0', 'z-0'); }
            });
            currentItem = index;
        }

        window.nextSlide = function() { showSlide(currentItem + 1); resetTimer(); }
        window.prevSlide = function() { showSlide(currentItem - 1); resetTimer(); }
        function startSlider() { slideInterval = setInterval(() => { nextSlide(); }, 5000); }
        function resetTimer() { clearInterval(slideInterval); startSlider(); }
        startSlider();
    });
</script>

<script>
    const chatButton = document.getElementById('chatButton');
    const chatWindow = document.getElementById('chatWindow');
    const chatMessages = document.getElementById('chatMessages');
    const messageInput = document.getElementById('messageInput');
    const sendButton = document.getElementById('sendButton');
    const typingIndicator = document.getElementById('typingIndicator');
    const notificationBadge = document.querySelector('.notification-badge');

    // Toggle chat window
    chatButton.addEventListener('click', () => {
        chatButton.classList.toggle('active');
        chatWindow.classList.toggle('active');
        if (chatWindow.classList.contains('active')) {
            messageInput.focus();
            notificationBadge.style.display = 'none';
        }
    });

    // Get current time
    function getCurrentTime() {
        const now = new Date();
        return now.getHours().toString().padStart(2, '0') + ':' + now.getMinutes().toString().padStart(2, '0');
    }

    // Add message to chat
    function addMessage(text, isUser = false) {
        const messageDiv = document.createElement('div');
        messageDiv.className = `message ${isUser ? 'user' : 'bot'}`;

        messageDiv.innerHTML = `
            <div class="message-avatar">${isUser ? '👤' : '🤖'}</div>
            <div class="message-content">
                <div class="message-bubble">${text}</div>
                <div class="message-time">${getCurrentTime()}</div>
            </div>
        `;

        // Insert before typing indicator
        chatMessages.insertBefore(messageDiv, typingIndicator);
        scrollToBottom();
    }

    // Show typing indicator
    function showTyping() {
        typingIndicator.classList.add('active');
        scrollToBottom();
    }

    // Hide typing indicator
    function hideTyping() {
        typingIndicator.classList.remove('active');
    }

    // Scroll to bottom
    function scrollToBottom() {
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    // Send message
    async function sendMessage() {
        const text = messageInput.value.trim();
        if (text === '') return;

        // Add user message
        addMessage(text, true);
        messageInput.value = '';

        // Disable send button
        sendButton.disabled = true;

        // Show typing indicator
        showTyping();

        try {
            const response = await fetch('/Chat/SendMessage', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ message: text })
            });

            const data = await response.json();

            hideTyping();
            addMessage(data.reply);

            if (data.product) {
                addProductCard(data.product);
            }

        } catch (error) {
            hideTyping();
            console.error('Error:', error);
            addMessage('Xin lỗi, hệ thống đang bận. Vui lòng thử lại sau. 😔');
        } finally {
            // Re-enable send button
            sendButton.disabled = false;
        }
    }

    // Quick reply
    function sendQuickReply(text) {
        messageInput.value = text;
        sendMessage();
    }

    // Handle "Xem đồng hồ mới" button - scroll to new products section
    function handleNewWatches() {
        // Close chatbot
        chatButton.classList.remove('active');
        chatWindow.classList.remove('active');

        // Find the "NEW PRODUCTS" section
        const newProductsSection = Array.from(document.querySelectorAll('h3')).find(
            h3 => h3.textContent.includes('NEW') && h3.textContent.includes('PRODUCTS')
        );

        if (newProductsSection) {
            // Scroll to the section with smooth behavior
            newProductsSection.closest('.w-full').scrollIntoView({
                behavior: 'smooth',
                block: 'start'
            });

            // Add a message to chat
            addMessage('Đây là các sản phẩm đồng hồ mới nhất của chúng tôi! 🆕', false);
        }
    }

    // Handle "Hãng đồng hồ" button - navigate to brands page
    function handleBrands() {
        // Add a message before navigating
        addMessage('Đang chuyển đến trang thương hiệu...', false);

        // Navigate to brands page after a short delay
        setTimeout(() => {
            window.location.href = '/Home/Brands';
        }, 500);
    }

    // Event listeners
    sendButton.addEventListener('click', sendMessage);
    messageInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
            sendMessage();
        }
    });

    //Add product cart
    function addProductCard(product) {
        const cardDiv = document.createElement('div');
        cardDiv.className = 'message bot';

        cardDiv.innerHTML = `
            <div class="message-avatar">🤖</div>
            <div class="message-content">
                <div class="product-card">
                    <img src="${product.imageUrl}" alt="${product.name}" />
                    <div class="product-info">
                        <div class="product-name">${product.name}</div>
                        <div class="product-price">${product.sellingPrice.toLocaleString('vi-VN', { style: 'currency', currency: 'VND' })}</div>
                    </div>
                </div>
                <div class="message-time">${getCurrentTime()}</div>
            </div>
        `;

        // Click vào ảnh => đi tới trang chi tiết
        const img = cardDiv.querySelector('img');
        img.addEventListener('click', () => {
            let url = "";

            if (product.watchType === "Mechanical") {
                url = `/Home/Mechanical/${product.productId}`;
            } else if (product.watchType === "Smartwatch") {
                url = `/Home/Smartwatch/${product.productId}`;
            } else {
                url = `/Home`;
            }

            window.location.href = url;
        });

        chatMessages.insertBefore(cardDiv, typingIndicator);
        scrollToBottom();
    }


    // Initial scroll
    scrollToBottom();
</script>