@model IEnumerable<WatchStoreApp.Models.Brand>

@{
    ViewData["Title"] = "Brands";
}

<div class="max-w-7xl mx-auto p-6 font-sans">

    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-600 mb-4">
        <a href="/Home" class="text-blue-500 hover:underline">Home</a>
        <span> / </span>
        <span class="font-medium">Brands</span>
    </nav>

    <!-- Title -->
    <h1 class="text-2xl font-bold uppercase mb-6 text-gray-800">BRANDS</h1>

    <!-- Brands Grid -->
    @if (Model != null && Model.Any())
    {
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
            @foreach (var brand in Model)
            {
                <a href="/Home/Brand/@brand.BrandId" class="bg-white p-4 rounded-lg shadow-sm hover:shadow-xl transition-shadow duration-300 group text-center border border-transparent hover:border-gray-100">
                    <div class="w-full h-32 flex items-center justify-center mb-4 overflow-hidden">
                        <img src="@brand.ImageUrl" alt="@brand.BrandName" class="max-h-full max-w-full object-contain group-hover:scale-110 transition-transform duration-500" onerror="this.src='https://images.unsplash.com/photo-1523170335258-f5ed11844a49?auto=format&fit=crop&q=80&w=600'">
                    </div>
                    <h4 class="text-sm font-semibold text-gray-800 mb-1 leading-snug line-clamp-2">
                        @brand.BrandName
                    </h4>
                    <p class="text-xs text-gray-500">@brand.Origin</p>
                </a>
            }
        </div>
    }
    else
    {
        <div class="text-center text-gray-500 py-16">
            <h5 class="text-lg">No brands found.</h5>
        </div>
    }
</div>

