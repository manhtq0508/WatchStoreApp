@model List<WatchStoreApp.Models.Product>
@{
    ViewBag.Title = "Search Results";
}

<div class="container mx-auto px-4 py-6">
    <h2 class="text-2xl font-semibold mb-6">Search Results for "@ViewBag.Query"</h2>

    @if (Model.Any())
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            @foreach (var product in Model)
            {
                var specs = $"{product.CaseDiameter}mm | {product.WatchType}";
                var imageUrl = string.IsNullOrEmpty(product.ImageUrl1)
                ? "https://images.unsplash.com/photo-1523170335258-f5ed11844a49?auto=format&fit=crop&q=80&w=600"
                : product.ImageUrl1;
                var price = product.SellingPrice.ToString("N0") + "₫";

                <div class="bg-white p-4 rounded-lg shadow-sm hover:shadow-xl transition-shadow duration-300 group text-center border border-transparent hover:border-gray-100">
                    <!-- Product Image -->
                    <div class="w-full h-64 flex items-center justify-center mb-4 overflow-hidden">
                        <img src="@imageUrl"
                             alt="@product.Name"
                             class="max-h-full max-w-full object-contain group-hover:scale-110 transition-transform duration-500"
                             onerror="this.src='https://images.unsplash.com/photo-1523170335258-f5ed11844a49?auto=format&fit=crop&q=80&w=600'">
                    </div>

                    <!-- Product Name -->
                    <h4 class="text-sm font-semibold text-gray-800 mb-1 leading-snug min-h-[40px] line-clamp-2">
                        @product.Name
                    </h4>

                    <!-- Product Specs -->
                    <p class="text-xs text-gray-500 mb-3">@specs</p>

                    <!-- Product Price -->
                    <p class="text-lg font-bold text-[#005844] mb-4">@price</p>

                    <!-- Add to Cart Button -->
                    <a href="@(product.WatchType == "Smartwatch" ? $"/Home/Smartwatch/{product.ProductId}" : $"/Home/Mechanical/{product.ProductId}")"
                       class="w-full py-2 text-white rounded font-medium transition-colors shadow-sm block text-center"
                       style="background-color: #005844;"
                       onmouseover="this.style.backgroundColor='#004535'"
                       onmouseout="this.style.backgroundColor='#005844'">
                        Add to Cart
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-gray-600">No products found matching your search.</p>
    }
</div>
