@model IEnumerable<WatchStoreApp.Models.Customer>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Customers";
    // Define theme color for borders and buttons based on the mockup
    var themeDarkGreen = "#004d40";
}

<div class="w-full p-8 bg-white font-sans">

    <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
        <h1 class="text-2xl font-bold text-gray-800 uppercase tracking-wide">CUSTOMERS</h1>

        <div class="flex items-center gap-4 w-full md:w-auto">
            <form asp-action="Search" method="post" class="relative flex-grow md:flex-grow-0 md:w-96">
                <input type="text" name="search_customer" placeholder="Enter name/email/phone number ..."
                       class="w-full pl-4 pr-10 py-2.5 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-[color:var(--theme)]" style="--theme:@themeDarkGreen" />
                <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                    <i class="bi bi-search text-lg"></i>
                </button>
            </form>

            <button name="btn_create"
                    class="px-8 py-2.5 bg-[color:var(--theme)] text-white font-medium rounded-md hover:opacity-90 transition shadow-sm uppercase" style="--theme:@themeDarkGreen">
                Create
            </button>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)]" style="--theme:@themeDarkGreen">ID</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)]" style="--theme:@themeDarkGreen">Customer Name</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)]" style="--theme:@themeDarkGreen">Date Of Birth</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)]" style="--theme:@themeDarkGreen">Phone Number</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)]" style="--theme:@themeDarkGreen">Email</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)] text-right" style="--theme:@themeDarkGreen"></th>
                </tr>
            </thead>
            <tbody class="text-gray-700">
                @foreach (var customer in Model)
                {
                    // Styling classes: Zebra striping and hover effect
                    var baseRowClass = "border-b border-gray-100 align-middle transition hover:bg-gray-50";
                    var stripeClass = "even:bg-gray-100";

                    <tr class="@baseRowClass @stripeClass">
                        <td class="py-6 px-6 text-lg font-medium">@customer.CustomerId</td>

                        <td class="py-6 px-6 text-lg">@customer.Name</td>

                        <td class="py-6 px-6 text-lg">@customer.DateOfBirth.ToString("dd/MM/yyyy")</td>

                        <td class="py-6 px-6 text-lg">@customer.PhoneNumber</td>

                        <td class="py-6 px-6 text-lg">@customer.Email</td>

                        <td class="py-6 px-6 text-right whitespace-nowrap">
                            <div class="flex justify-end items-center gap-4 text-xl">
                                <button type="button" class="text-gray-600 hover:text-blue-600 transition" title="Edit"
                                        onclick="window.location.href='/Customer/Edit?id=@customer.CustomerId'">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                                <button type="button" class="text-gray-600 hover:text-red-600 transition" title="Delete"
                                        onclick="window.location.href='/Customer/Delete?id=@customer.CustomerId'">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    document.getElementsByName("btn_create")[0].onclick = function () {
        window.location.href = "/Customer/Create";
    };
</script>