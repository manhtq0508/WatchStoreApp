<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WatchStoreApp</title>
    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }

        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</head>
<body class="bg-gray-100 font-sans h-screen flex flex-col overflow-hidden">

    <div class="relative z-40 bg-white flex-none shadow-sm">
        @await Html.PartialAsync("_Header")
    </div>

    <div class="flex flex-1 overflow-hidden">

        <aside id="sidebar" class="w-64 bg-[#2C3338] text-gray-200 flex-none overflow-y-auto no-scrollbar border-r border-gray-700/50">
            <div class="py-6 px-3">
                <nav class="space-y-1">
                    @{
                        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

                        bool isAdmin = User.IsInRole("Admin");
                        bool isEmployee = User.IsInRole("Employee");

                        bool IsActive(string controller, string action = null)
                        {
                            if (action == null)
                                return currentController?.Equals(controller, StringComparison.OrdinalIgnoreCase) == true;
                            return currentController?.Equals(controller, StringComparison.OrdinalIgnoreCase) == true
                            && currentAction?.Equals(action, StringComparison.OrdinalIgnoreCase) == true;
                        }

                        string GetActiveClass(string controller, string action = null)
                        {
                            return IsActive(controller, action)
                            ? "bg-gray-700 text-white border-l-4 border-[#005844]"
                            : "text-gray-300 hover:bg-gray-700/50 hover:text-white transition-colors duration-200 border-l-4 border-transparent";
                        }
                        var iconClass = "w-5 h-5 mr-3 text-lg transition-colors duration-200";
                    }

                    <a href="/Dashboard" class="flex items-center px-4 py-3 rounded-r-lg group @GetActiveClass("Dashboard")">
                        <i class="bi bi-speedometer2 @iconClass group-hover:text-white @(IsActive("Dashboard") ? "text-white" : "text-gray-400")"></i>
                        <span>Dashboard</span>
                    </a>
                    <a href="/Product" class="flex items-center px-4 py-3 rounded-r-lg group @GetActiveClass("Product")">
                        <i class="bi bi-box-seam @iconClass group-hover:text-white @(IsActive("Product") ? "text-white" : "text-gray-400")"></i>
                        <span>Products</span>
                    </a>

                    @if (isAdmin)
                    {
                        <a href="/Brand" class="flex items-center px-4 py-3 rounded-r-lg group @GetActiveClass("Brand")">
                            <i class="bi bi-clock @iconClass"></i>
                            <span>Brands</span>
                        </a>

                        <a href="/Coupon" class="flex items-center px-4 py-3 rounded-r-lg group @GetActiveClass("Coupon")">
                            <i class="bi bi-ticket-perforated @iconClass"></i>
                            <span>Coupons</span>
                        </a>

                    }

                    <a href="/Import" class="flex items-center px-4 py-3 rounded-r-lg group @GetActiveClass("Import")">
                        <i class="bi bi-arrow-down-circle @iconClass"></i>
                        <span>Imports</span>
                    </a>

                    <a href="/Invoice" class="flex items-center px-4 py-3 rounded-r-lg group @GetActiveClass("Invoice")">
                        <i class="bi bi-receipt @iconClass group-hover:text-white @(IsActive("Invoice") ? "text-white" : "text-gray-400")"></i>
                        <span>Invoices</span>
                    </a>
                    <a href="/Customer" class="flex items-center px-4 py-3 rounded-r-lg group @GetActiveClass("Customer")">
                        <i class="bi bi-people @iconClass group-hover:text-white @(IsActive("Customer") ? "text-white" : "text-gray-400")"></i>
                        <span>Customers</span>
                    </a>
                    @if (isAdmin)
                    {
                        <a href="/Employee" class="flex items-center px-4 py-3 rounded-r-lg group @GetActiveClass("Employee")">
                            <i class="bi bi-person-badge @iconClass"></i>
                            <span>Employees</span>
                        </a>
                    }

                    <a href="/Account" class="flex items-center px-4 py-3 rounded-r-lg group @GetActiveClass("Account")">
                        <i class="bi bi-person-circle @iconClass group-hover:text-white @(IsActive("Account") ? "text-white" : "text-gray-400")"></i>
                        <span>Account</span>
                    </a>

                    <hr class="border-gray-700/50 my-4 mx-4" />

                    @if (isAdmin)
                    {
                        <a href="/Settings" class="flex items-center px-4 py-3 rounded-r-lg group @GetActiveClass("Settings")">
                            <i class="bi bi-gear @iconClass group-hover:text-white @(IsActive("Settings") ? "text-white" : "text-gray-400")"></i>
                            <span>Settings</span>
                        </a>
                    }


                    <a href="/Signin/Logout" class="flex items-center px-4 py-3 text-red-400 transition-colors duration-200 rounded-r-lg hover:bg-red-500/10 hover:text-red-300 group mt-auto mb-6">
                        <i class="bi bi-box-arrow-right @iconClass"></i>
                        <span>Logout</span>
                    </a>
                </nav>
            </div>
        </aside>

        <main class="flex-1 overflow-y-auto bg-gray-100 relative w-full">
            <div class="flex flex-col min-h-full">
                <div class="p-6 flex-grow">
                    @RenderBody()
                </div>

                <div class="mt-auto">
                    @await Html.PartialAsync("_Footer")
                </div>
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>