@model WatchStoreApp.Models.Employee
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Employee";
    // Define theme color based on the mockup's green button
    var themeGreen = "#005844";
}

<div class="w-full p-8 bg-white font-sans">
    <h1 class="text-2xl font-bold mb-10 uppercase text-gray-800">UPDATE EMPLOYEE INFORMATION</h1>

    <div class="max-w-4xl">
        <form method="post" class="space-y-8">
            <input type="hidden" asp-for="EmployeeId" />

            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 items-center">
                <label asp-for="Name" class="block text-lg font-medium text-gray-700 md:col-span-1">Employee Name</label>
                <div class="md:col-span-3">
                    <input asp-for="Name" placeholder="Employee Name"
                           class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="Name" class="text-red-600 text-sm mt-1 block"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 items-center">
                <label asp-for="CardNumber" class="block text-lg font-medium text-gray-700 md:col-span-1">Citizen ID Card</label>
                <div class="md:col-span-3">
                    <input asp-for="CardNumber" placeholder="Citizen ID Card"
                           class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="CardNumber" class="text-red-600 text-sm mt-1 block"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 items-center">
                <label asp-for="PhoneNumber" class="block text-lg font-medium text-gray-700 md:col-span-1">Phone Number</label>
                <div class="md:col-span-3">
                    <input asp-for="PhoneNumber" placeholder="Phone Number"
                           class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="PhoneNumber" class="text-red-600 text-sm mt-1 block"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 items-center">
                <label asp-for="Role" class="block text-lg font-medium text-gray-700 md:col-span-1">Role</label>
                <div class="md:col-span-3">
                    <select asp-for="Role"
                            class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent appearance-none bg-no-repeat bg-[center_right_1rem]" style="--themeGreen: @themeGreen; background-image: url('data:image/svg+xml,%3csvg xmlns=\'http://www.w3.org/2000/svg\' fill=\'none\' viewBox=\'0 0 20 20\'%3e%3cpath stroke=\'%236b7280\' stroke-linecap=\'round\' stroke-linejoin=\'round\' stroke-width=\'1.5\' d=\'M6 8l4 4 4-4\'/%3e%3c/svg%3e');">
                        <option value="" class="text-gray-400">Role</option>
                        <option value="Admin">Admin</option>
                        <option value="Employee">Employee</option>
                    </select>
                    <span asp-validation-for="Role" class="text-red-600 text-sm mt-1 block"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 items-center">
                <label asp-for="Email" class="block text-lg font-medium text-gray-700 md:col-span-1">Email</label>
                <div class="md:col-span-3">
                    <input asp-for="Email" type="email" placeholder="Email"
                           class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="Email" class="text-red-600 text-sm mt-1 block"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 items-center">
                <label asp-for="Password" class="block text-lg font-medium text-gray-700 md:col-span-1">Password</label>
                <div class="md:col-span-3">
                    <input asp-for="Password" type="password" placeholder="Password"
                           class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="Password" class="text-red-600 text-sm mt-1 block"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 items-center">
                <label asp-for="IsAvailable" class="block text-lg font-medium text-gray-700 md:col-span-1">Status</label>
                <div class="md:col-span-3">
                    <select asp-for="IsAvailable"
                            class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent appearance-none bg-no-repeat bg-[center_right_1rem]" style="--themeGreen: @themeGreen; background-image: url('data:image/svg+xml,%3csvg xmlns=\'http://www.w3.org/2000/svg\' fill=\'none\' viewBox=\'0 0 20 20\'%3e%3cpath stroke=\'%236b7280\' stroke-linecap=\'round\' stroke-linejoin=\'round\' stroke-width=\'1.5\' d=\'M6 8l4 4 4-4\'/%3e%3c/svg%3e');">
                        <option value="" class="text-gray-400">Status</option>
                        <option value="true">Active</option>
                        <option value="false">Inactive</option>
                    </select>
                    <span asp-validation-for="IsAvailable" class="text-red-600 text-sm mt-1 block"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 items-center pt-6">
                <div class="md:col-span-1"></div> <div class="md:col-span-3">
                    <button type="submit" class="w-full px-12 py-3 bg-[color:var(--themeGreen)] text-white text-lg font-medium rounded hover:opacity-90 transition shadow-sm uppercase" style="--themeGreen: @themeGreen">
                        Update Employee
                    </button>
                </div>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}