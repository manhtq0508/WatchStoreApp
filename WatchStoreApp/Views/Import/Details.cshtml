@model WatchStoreApp.Models.ImportBill
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Import Bill Details";
    // Define theme color based on the mockup
    var themeGreen = "#005844";
}

<div class="w-full p-8 bg-white font-sans">
    <h1 class="text-2xl font-bold mb-10 uppercase text-gray-800">IMPORT DETAILS</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6 mb-12 text-lg">

        <div class="space-y-6 font-medium text-gray-700">
            <div>Import ID</div>
            <div>Employee Name</div>
            <div>Import Date</div>
            <div>Total</div>
        </div>

        <div class="space-y-6 font-semibold text-gray-900">
            <div>@Model.ImportBillId</div>
            <div>@Model.Employee?.Name</div>
            <div>@Model.Date.ToString("dd/MM/yyyy")</div>
            <div>@Model.Total.ToString("N0") ₫</div>
        </div>
    </div>


    <div>
        <h2 class="text-2xl font-bold mb-6 text-gray-800">Product List</h2>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr>
                        <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--themeGreen)]" style="--themeGreen: @themeGreen">ID</th>
                        <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--themeGreen)] w-1/3" style="--themeGreen: @themeGreen">Product Name</th>
                        <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--themeGreen)] text-right" style="--themeGreen: @themeGreen">Price</th>
                        <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--themeGreen)] text-center" style="--themeGreen: @themeGreen">Quantity</th>
                        <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--themeGreen)] text-right" style="--themeGreen: @themeGreen">Total</th>
                    </tr>
                </thead>
                <tbody class="text-gray-700">
                    @if (Model.ImportDetails != null && Model.ImportDetails.Any())
                    {
                        int i = 1;
                        foreach (var d in Model.ImportDetails)
                        {
                            // Styling classes: Zebra striping and hover effect
                            var baseRowClass = "border-b border-gray-100 align-middle transition hover:bg-gray-50";
                            var stripeClass = "even:bg-gray-100";

                            <tr class="@baseRowClass @stripeClass">
                                <td class="py-6 px-6 text-lg font-medium">@i</td>

                                <td class="py-6 px-6 text-lg">@d.Product?.Name</td>

                                <td class="py-6 px-6 text-lg text-right">@d.Price.ToString("N0") ₫</td>

                                <td class="py-6 px-6 text-lg text-center">@d.Quantity</td>

                                <td class="py-6 px-6 text-lg text-right font-medium">@d.Total.ToString("N0") ₫</td>
                            </tr>
                            i++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="py-6 px-6 text-center text-gray-500 text-lg">No products found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-12">
        <a asp-action="Index" class="inline-flex items-center px-6 py-3 border border-gray-300 shadow-sm text-lg font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[color:var(--themeGreen)] transition" style="--themeGreen: @themeGreen">
            <i class="bi bi-arrow-left mr-2"></i> Back to List
        </a>
    </div>
</div>