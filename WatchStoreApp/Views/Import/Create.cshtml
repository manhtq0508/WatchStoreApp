@model WatchStoreApp.ViewModel.Import.CreateBillVM
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Create Import Bill";
    // Define theme color based on the mockup's green button
    var themeGreen = "#005844";
}

<div class="w-full p-8 bg-white font-sans">
    <h1 class="text-2xl font-bold mb-10 uppercase text-gray-800">CREATE A NEW IMPORT</h1>

    <form asp-action="Create" method="post" class="max-w-4xl space-y-8">
        <input type="hidden" asp-for="EmployeeId" />
        <input type="hidden" asp-for="Total" id="hiddenTotal" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6 items-start">
            <div class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-center">
                    <label class="block text-lg font-medium text-gray-700 md:col-span-1">Employee Name</label>
                    <div class="md:col-span-2">
                        <input type="text" value="@Model.EmployeeName" readonly
                               class="w-full px-4 py-3 border border-transparent rounded bg-transparent text-gray-900 text-lg font-medium focus:outline-none cursor-default" />
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-center">
                    <label asp-for="Date" class="block text-lg font-medium text-gray-700 md:col-span-1">Import Date</label>
                    <div class="md:col-span-2">
                        <input asp-for="Date" type="date" value="@Model.Date.ToString("yyyy-MM-dd")"
                               class="w-full px-4 py-3 border border-transparent rounded bg-transparent text-gray-900 text-lg font-medium focus:outline-none cursor-default font-sans" />
                    </div>
                </div>
            </div>

            <div class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-center">
                    <label class="block text-lg font-medium text-gray-700 md:col-span-1">Product</label>
                    <div class="md:col-span-2">
                        <select id="productSelect"
                                class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent appearance-none bg-no-repeat bg-[center_right_1rem]" style="--themeGreen: @themeGreen; background-image: url('data:image/svg+xml,%3csvg xmlns=\'http://www.w3.org/2000/svg\' fill=\'none\' viewBox=\'0 0 20 20\'%3e%3cpath stroke=\'%236b7280\' stroke-linecap=\'round\' stroke-linejoin=\'round\' stroke-width=\'1.5\' d=\'M6 8l4 4 4-4\'/%3e%3c/svg%3e');">
                            <option value="" class="text-gray-400">Product</option>
                            @foreach (var p in Model.Products!)
                            {
                                <option value="@p.ProductId" data-price="@p.ImportPrice">@p.Name</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-center">
                    <label class="block text-lg font-medium text-gray-700 md:col-span-1">Quantity</label>
                    <div class="md:col-span-2">
                        <input id="quantityInput" type="number" min="1" value="1" placeholder="Quantity"
                               class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-center pt-2">
                    <div class="md:col-span-1"></div>
                    <div class="md:col-span-2">
                        <button type="button" id="btnAdd"
                                class="w-full px-6 py-3 bg-[color:var(--themeGreen)] text-white text-lg font-medium rounded hover:opacity-90 transition shadow-sm uppercase" style="--themeGreen: @themeGreen">
                            Select
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-12">
            <h2 class="text-2xl font-bold mb-6 text-gray-800">Product List</h2>

            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse" id="productTable">
                    <thead>
                        <tr>
                            <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--themeGreen)]" style="--themeGreen: @themeGreen">ID</th>
                            <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--themeGreen)] w-1/3" style="--themeGreen: @themeGreen">Product Name</th>
                            <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--themeGreen)] text-right" style="--themeGreen: @themeGreen">Price</th>
                            <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--themeGreen)] text-center" style="--themeGreen: @themeGreen">Quantity</th>
                            <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--themeGreen)] text-right" style="--themeGreen: @themeGreen">Total</th>
                            <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--themeGreen)]" style="--themeGreen: @themeGreen"></th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-700">
                    </tbody>
                </table>
            </div>
        </div>

        <div class="flex flex-col md:flex-row justify-between items-center mt-12 p-6 bg-gray-50 rounded-lg">
            <h4 class="text-2xl font-bold text-gray-800 mb-4 md:mb-0 flex items-center">
                Total: <span id="totalAmount" class="text-[color:var(--themeGreen)] ml-4" style="--themeGreen: @themeGreen">0₫</span>
            </h4>

            <button type="submit"
                    class="px-12 py-3 bg-[color:var(--themeGreen)] text-white text-lg font-medium rounded hover:opacity-90 transition shadow-sm uppercase" style="--themeGreen: @themeGreen">
                Checkout
            </button>
        </div>

        <div id="detailsContainer"></div>
    </form>
</div>

@section Scripts {
    <script>
        let index = 0;
        const themeGreen = "#005844"; // Define color for JS use if needed

        document.getElementById("btnAdd").addEventListener("click", function () {
            const productSelect = document.getElementById("productSelect");
            const quantityInput = document.getElementById("quantityInput");

            const productId = productSelect.value;
            const productName = productSelect.options[productSelect.selectedIndex].text;
            const price = parseFloat(productSelect.options[productSelect.selectedIndex].dataset.price || 0);
            const quantity = parseInt(quantityInput.value);

            if (!productId || quantity <= 0) {
                alert("Vui lòng chọn sản phẩm và số lượng hợp lệ!");
                return;
            }

            const existingRow = [...document.querySelectorAll("#productTable tbody tr")]
                .find(r => r.children[0].textContent.trim() === productId);

            if (existingRow) {
                // Nếu sản phẩm đã có => cộng dồn số lượng
                const currentQty = parseInt(existingRow.children[3].textContent);
                const newQty = currentQty + quantity;
                existingRow.children[3].textContent = newQty;
                const newTotal = newQty * price;
                existingRow.children[4].textContent = newTotal.toLocaleString() + "₫";

                // Cập nhật input hidden Quantity
                // Logic changed: find input by data-id attribute instead of name pattern
                const qtyInput = document.querySelector(`#detailsContainer input[name*=".Quantity"][data-id="${productId}"]`);
                if (qtyInput) qtyInput.value = newQty;
                updateTotal();
            } else {
                // Thêm dòng mới
                const total = price * quantity;

                const tbody = document.querySelector("#productTable tbody");
                const row = document.createElement("tr");
                // Redesigned row styling: zebra striping, hover effect, larger text, specific alignments
                row.className = "border-b border-gray-100 align-middle transition hover:bg-gray-50 even:bg-gray-100";
                row.innerHTML = `
                    <td class="py-6 px-6 text-lg font-medium text-gray-900">${productId}</td>
                    <td class="py-6 px-6 text-lg text-gray-900">${productName}</td>
                    <td class="py-6 px-6 text-lg text-gray-900 text-right">${price.toLocaleString()}₫</td>
                    <td class="py-6 px-6 text-lg text-gray-900 text-center">${quantity}</td>
                    <td class="py-6 px-6 text-lg text-gray-900 text-right font-medium">${total.toLocaleString()}₫</td>
                    <td class="py-6 px-6 text-right">
                        <button type="button" class="text-gray-400 hover:text-[color:var(--themeGreen)] transition remove" style="--themeGreen: ${themeGreen}" title="Remove">
                            <i class="bi bi-trash3 text-xl pointer-events-none"></i> </button>
                    </td>
                `;
                tbody.appendChild(row);

                const container = document.getElementById("detailsContainer");
                container.insertAdjacentHTML("beforeend", `
                    <input type="hidden" name="ImportDetails[${index}].ProductId" value="${productId}" data-id="${productId}" />
                    <input type="hidden" name="ImportDetails[${index}].Quantity" value="${quantity}" data-id="${productId}" />
                    <input type="hidden" name="ImportDetails[${index}].Price" value="${price}" data-id="${productId}" />
                `);
                index++;
                updateTotal();
            }

            // Reset lựa chọn
            productSelect.value = "";
            quantityInput.value = 1;
        });

        // Xóa dòng + input hidden tương ứng
        document.addEventListener("click", function (e) {
            // Check if the clicked element or its parent is the remove button
            const removeButton = e.target.closest(".remove");
            if (removeButton) {
                const row = removeButton.closest("tr");
                const productId = row.children[0].textContent.trim();
                row.remove();

                // Xóa các input hidden tương ứng
                document.querySelectorAll(`#detailsContainer input[data-id="${productId}"]`).forEach(el => el.remove());
                updateTotal();
            }
        });

        // Cập nhật tổng tiền
        function updateTotal() {
            let total = 0;
            const qtyInputs = document.querySelectorAll('#detailsContainer input[name*=".Quantity"]');

            qtyInputs.forEach(qtyInput => {
                const id = qtyInput.getAttribute('data-id');
                const priceInput = document.querySelector(`#detailsContainer input[name*=".Price"][data-id="${id}"]`);

                if (priceInput) {
                    const q = parseFloat(qtyInput.value) || 0;
                    const p = parseFloat(priceInput.value) || 0;

                    total += (q * p);
                }
            });
            document.getElementById("totalAmount").textContent = total.toLocaleString('vi-VN') + "₫";
            document.getElementById("hiddenTotal").value = total;
        }
    </script>
}