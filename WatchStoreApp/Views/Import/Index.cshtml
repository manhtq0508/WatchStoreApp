@model IEnumerable<WatchStoreApp.ViewModel.Import.ViewListImportBillVM>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Import Bills";
    // Define theme color for borders and buttons based on the mockup
    var themeDarkGreen = "#004d40";
}

<div class="w-full p-8 bg-white font-sans">

    <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
        <h1 class="text-2xl font-bold text-gray-800 uppercase tracking-wide">IMPORTS</h1>

        <div class="flex items-center gap-4 w-full md:w-auto">
            <form asp-action="Search" method="post" class="relative flex-grow md:flex-grow-0 md:w-[400px]">
                <input type="text" name="search_import" placeholder="Enter import ID / employee name ..."
                       class="w-full pl-4 pr-10 py-2.5 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-[color:var(--theme)]" style="--theme:@themeDarkGreen" />
                <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                    <i class="bi bi-search text-lg"></i>
                </button>
            </form>

            <button name="btn_create"
                    class="px-8 py-2.5 bg-[color:var(--theme)] text-white font-medium rounded-md hover:opacity-90 transition shadow-sm uppercase" style="--theme:@themeDarkGreen">
                Create
            </button>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)]" style="--theme:@themeDarkGreen">ID</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)]" style="--theme:@themeDarkGreen">Employee ID</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)]" style="--theme:@themeDarkGreen">Employee Name</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)]" style="--theme:@themeDarkGreen">Import Date</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)]" style="--theme:@themeDarkGreen">Total</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)] text-right" style="--theme:@themeDarkGreen"></th>
                </tr>
            </thead>
            <tbody class="text-gray-700">
                @foreach (var bill in Model)
                {
                    // Styling classes: Zebra striping and hover effect
                    var baseRowClass = "border-b border-gray-100 align-middle transition hover:bg-gray-50";
                    var stripeClass = "even:bg-gray-100";

                    <tr class="@baseRowClass @stripeClass">
                        <td class="py-6 px-6 text-lg font-medium">@bill.ImportBillId</td>

                        <td class="py-6 px-6 text-lg">@bill.EmployeeId</td>

                        <td class="py-6 px-6 text-lg">@bill.EmployeeName</td>

                        <td class="py-6 px-6 text-lg">@bill.Date.ToString("dd/MM/yyyy")</td>

                        <td class="py-6 px-6 text-lg">@bill.Total.ToString("N0") ₫</td>

                        <td class="py-6 px-6 text-right whitespace-nowrap">
                            <a asp-action="Details" asp-route-id="@bill.ImportBillId" class="text-gray-600 hover:text-blue-600 transition text-xl" title="View Details">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    document.getElementsByName("btn_create")[0].onclick = function () {
        window.location.href = "/Import/Create";
    };
</script>