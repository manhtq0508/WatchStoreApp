@model WatchStoreApp.ViewModel.Product.EditSmartwatchVM

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Smartwatch";
    // Define theme color for consistency with the mockup
    var themeGreen = "#005844";
}

<div class="w-full p-8 bg-white font-sans">
    <h1 class="text-2xl font-bold mb-10 uppercase text-gray-800">UPDATE PRODUCT INFORMATION</h1>

    <div class="max-w-4xl">

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">

            <form asp-action="EditImage1" method="post" enctype="multipart/form-data">
                <input asp-for="@Model.ProductId" type="hidden" />
                <p class="text-lg font-medium text-gray-700 mb-2">Image 1</p>
                <label for="ImageUrl1" class="flex flex-col items-center justify-center w-full h-48 border-2 border-gray-300 border-dashed rounded-lg cursor-pointer bg-gray-50 hover:bg-gray-100 transition group relative overflow-hidden">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl1Path))
                    {
                        // Show current image
                        <img src="@Model.ImageUrl1Path" alt="Image 1" class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-75 transition" />
                    }
                    <div class="flex flex-col items-center justify-center pt-5 pb-6 relative z-10">
                        <p class="mb-2 text-sm text-gray-600 font-medium text-center px-2" id="fileNameDisplay-ImageUrl1">
                            @(!string.IsNullOrEmpty(Model.ImageUrl1Path) ? "Change image" : "Choose image")
                        </p>
                        <div class="px-6 py-1.5 bg-[#4F93E7] text-white text-sm rounded shadow-sm group-hover:bg-blue-600 transition">Upload</div>
                    </div>
                    <input asp-for="ImageUrl1" type="file" id="ImageUrl1" accept="image/*" class="hidden" onchange="this.form.submit()" />
                </label>
                <span asp-validation-for="ImageUrl1" class="text-red-600 text-sm mt-1 block"></span>
            </form>

            <form asp-action="EditImage2" method="post" enctype="multipart/form-data">
                <input asp-for="@Model.ProductId" type="hidden" />
                <p class="text-lg font-medium text-gray-700 mb-2">Image 2</p>
                <label for="ImageUrl2" class="flex flex-col items-center justify-center w-full h-48 border-2 border-gray-300 border-dashed rounded-lg cursor-pointer bg-gray-50 hover:bg-gray-100 transition group relative overflow-hidden">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl2Path))
                    {
                        <img src="@Model.ImageUrl2Path" alt="Image 2" class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-75 transition" />
                    }
                    <div class="flex flex-col items-center justify-center pt-5 pb-6 relative z-10">
                        <p class="mb-2 text-sm text-gray-600 font-medium text-center px-2" id="fileNameDisplay-ImageUrl2">
                            @(!string.IsNullOrEmpty(Model.ImageUrl2Path) ? "Change image" : "Choose image")
                        </p>
                        <div class="px-6 py-1.5 bg-[#4F93E7] text-white text-sm rounded shadow-sm group-hover:bg-blue-600 transition">Upload</div>
                    </div>
                    <input asp-for="ImageUrl2" type="file" id="ImageUrl2" accept="image/*" class="hidden" onchange="this.form.submit()" />
                </label>
                <span asp-validation-for="ImageUrl2" class="text-red-600 text-sm mt-1 block"></span>
            </form>

            <form asp-action="EditImage3" method="post" enctype="multipart/form-data">
                <input asp-for="@Model.ProductId" type="hidden" />
                <p class="text-lg font-medium text-gray-700 mb-2">Image 3</p>
                <label for="ImageUrl3" class="flex flex-col items-center justify-center w-full h-48 border-2 border-gray-300 border-dashed rounded-lg cursor-pointer bg-gray-50 hover:bg-gray-100 transition group relative overflow-hidden">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl3Path))
                    {
                        <img src="@Model.ImageUrl3Path" alt="Image 3" class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-75 transition" />
                    }
                    <div class="flex flex-col items-center justify-center pt-5 pb-6 relative z-10">
                        <p class="mb-2 text-sm text-gray-600 font-medium text-center px-2" id="fileNameDisplay-ImageUrl3">
                            @(!string.IsNullOrEmpty(Model.ImageUrl3Path) ? "Change image" : "Choose image")
                        </p>
                        <div class="px-6 py-1.5 bg-[#4F93E7] text-white text-sm rounded shadow-sm group-hover:bg-blue-600 transition">Upload</div>
                    </div>
                    <input asp-for="ImageUrl3" type="file" id="ImageUrl3" accept="image/*" class="hidden" onchange="this.form.submit()" />
                </label>
                <span asp-validation-for="ImageUrl3" class="text-red-600 text-sm mt-1 block"></span>
            </form>
        </div>


        <form asp-action="EditSmartwatch" method="post" class="space-y-8">
            <input type="hidden" asp-for="ProductId" />

            <h2 class="text-xl font-bold text-gray-800 mb-6">Technical Specifications</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6 items-center">

                <label asp-for="Name" class="block text-lg font-medium text-gray-700">Product Name</label>
                <div class="relative">
                    <input asp-for="Name" placeholder="Product Name" class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="Name" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <label asp-for="BrandId" class="block text-lg font-medium text-gray-700">Brand</label>
                <div class="relative">
                    <select asp-for="BrandId" asp-items="Model.BrandList" class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent appearance-none bg-no-repeat bg-[center_right_1rem]" style="--themeGreen: @themeGreen; background-image: url('data:image/svg+xml,%3csvg xmlns=\'http://www.w3.org/2000/svg\' fill=\'none\' viewBox=\'0 0 20 20\'%3e%3cpath stroke=\'%236b7280\' stroke-linecap=\'round\' stroke-linejoin=\'round\' stroke-width=\'1.5\' d=\'M6 8l4 4 4-4\'/%3e%3c/svg%3e');">
                        <option value="" class="text-gray-400">Brand</option>
                    </select>
                    <span asp-validation-for="BrandId" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <label asp-for="Gender" class="block text-lg font-medium text-gray-700">Gender</label>
                <div class="relative">
                    <select asp-for="Gender" asp-items="Model.GenderList" class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent appearance-none bg-no-repeat bg-[center_right_1rem]" style="--themeGreen: @themeGreen; background-image: url('data:image/svg+xml,%3csvg xmlns=\'http://www.w3.org/2000/svg\' fill=\'none\' viewBox=\'0 0 20 20\'%3e%3cpath stroke=\'%236b7280\' stroke-linecap=\'round\' stroke-linejoin=\'round\' stroke-width=\'1.5\' d=\'M6 8l4 4 4-4\'/%3e%3c/svg%3e');">
                        <option value="" class="text-gray-400">Gender</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <label asp-for="GlassMaterial" class="block text-lg font-medium text-gray-700">Glass Material</label>
                <div class="relative">
                    <input asp-for="GlassMaterial" placeholder="Glass Material" class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="GlassMaterial" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <label asp-for="CaseDiameter" class="block text-lg font-medium text-gray-700">Case Diameter</label>
                <div class="relative">
                    <input asp-for="CaseDiameter" placeholder="Case Diameter" class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="CaseDiameter" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <label asp-for="CaseThickness" class="block text-lg font-medium text-gray-700">Case Thickness</label>
                <div class="relative">
                    <input asp-for="CaseThickness" placeholder="Case Thickness" class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="CaseThickness" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <label asp-for="WaterResistance" class="block text-lg font-medium text-gray-700">Water Resistance</label>
                <div class="relative">
                    <input asp-for="WaterResistance" placeholder="Water Resistance" class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="WaterResistance" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <label asp-for="ProductGenre" class="block text-lg font-medium text-gray-700">Product Genre</label>
                <div class="relative">
                    <input asp-for="ProductGenre" placeholder="Product Genre" class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="ProductGenre" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <label asp-for="StrapMaterial" class="block text-lg font-medium text-gray-700">Strap Material</label>
                <div class="relative">
                    <select asp-for="StrapMaterial" asp-items="Model.StrapMaterialList" class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent appearance-none bg-no-repeat bg-[center_right_1rem]" style="--themeGreen: @themeGreen; background-image: url('data:image/svg+xml,%3csvg xmlns=\'http://www.w3.org/2000/svg\' fill=\'none\' viewBox=\'0 0 20 20\'%3e%3cpath stroke=\'%236b7280\' stroke-linecap=\'round\' stroke-linejoin=\'round\' stroke-width=\'1.5\' d=\'M6 8l4 4 4-4\'/%3e%3c/svg%3e');">
                        <option value="" class="text-gray-400">Strap Material</option>
                    </select>
                    <span asp-validation-for="StrapMaterial" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <label asp-for="StrapColor" class="block text-lg font-medium text-gray-700">Strap Color</label>
                <div class="relative">
                    <input asp-for="StrapColor" placeholder="Strap Color" class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="StrapColor" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <label asp-for="WatchStyle" class="block text-lg font-medium text-gray-700">Watch Style</label>
                <div class="relative">
                    <select asp-for="WatchStyle" asp-items="Model.WatchStyleList" class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent appearance-none bg-no-repeat bg-[center_right_1rem]" style="--themeGreen: @themeGreen; background-image: url('data:image/svg+xml,%3csvg xmlns=\'http://www.w3.org/2000/svg\' fill=\'none\' viewBox=\'0 0 20 20\'%3e%3cpath stroke=\'%236b7280\' stroke-linecap=\'round\' stroke-linejoin=\'round\' stroke-width=\'1.5\' d=\'M6 8l4 4 4-4\'/%3e%3c/svg%3e');">
                        <option value="" class="text-gray-400">Watch Style</option>
                    </select>
                    <span asp-validation-for="WatchStyle" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <label asp-for="WarrantyPeriod" class="block text-lg font-medium text-gray-700">Warranty Period</label>
                <div class="relative">
                    <input asp-for="WarrantyPeriod" placeholder="Warranty Period" class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="WarrantyPeriod" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <label asp-for="BateryLife" class="block text-lg font-medium text-gray-700">Battery Life</label>
                <div class="relative">
                    <input asp-for="BateryLife" placeholder="Battery Life" class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="BateryLife" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <label asp-for="DisplayResolution" class="block text-lg font-medium text-gray-700">Display Resolution</label>
                <div class="relative">
                    <input asp-for="DisplayResolution" placeholder="Display Resolution" class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="DisplayResolution" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <label asp-for="DisplayTechnology" class="block text-lg font-medium text-gray-700">Display Technology</label>
                <div class="relative">
                    <input asp-for="DisplayTechnology" placeholder="Display Technology" class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="DisplayTechnology" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <label asp-for="ScreenSize" class="block text-lg font-medium text-gray-700">Screen Size</label>
                <div class="relative">
                    <input asp-for="ScreenSize" placeholder="Screen Size" class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="ScreenSize" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <label asp-for="Sensors" class="block text-lg font-medium text-gray-700">Sensors</label>
                <div class="relative">
                    <input asp-for="Sensors" placeholder="Sensors" class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="Sensors" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <label asp-for="ImportPrice" class="block text-lg font-medium text-gray-700">Import Price</label>
                <div class="relative">
                    <input asp-for="ImportPrice" type="number" placeholder="Import Price" class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="ImportPrice" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <label asp-for="SellingPrice" class="block text-lg font-medium text-gray-700">Retail Price</label>
                <div class="relative">
                    <input asp-for="SellingPrice" type="number" placeholder="Retail Price" class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[color:var(--themeGreen)] focus:border-transparent placeholder-gray-400" style="--themeGreen: @themeGreen" />
                    <span asp-validation-for="SellingPrice" class="text-red-600 text-sm mt-1 block"></span>
                </div>

                <label asp-for="StockQuantity" class="block text-lg font-medium text-gray-700">Quantity</label>
                <div class="relative">
                    <input asp-for="StockQuantity" readonly class="w-full px-4 py-3 border border-gray-300 rounded bg-gray-100 text-gray-700 focus:outline-none cursor-default" />
                    <span asp-validation-for="StockQuantity" class="text-red-600 text-sm mt-1 block"></span>
                </div>

            </div>

            <div class="pt-8">
                <div class="flex justify-center">
                    <button type="submit" class="w-full md:w-auto px-12 py-3 bg-[color:var(--themeGreen)] text-white text-lg font-medium rounded hover:opacity-90 transition shadow-sm uppercase" style="--themeGreen: @themeGreen">
                        Update Product
                    </button>
                </div>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            ['ImageUrl1', 'ImageUrl2', 'ImageUrl3'].forEach(function(id) {
                const input = document.getElementById(id);
                if (input) {
                    input.addEventListener('change', function(e) {
                        const fileName = e.target.files[0] ? e.target.files[0].name : "Change image";
                        document.getElementById(`fileNameDisplay-${id}`).textContent = fileName;
                        // Submit the form automatically when a file is selected
                        this.form.submit();
                    });
                }
            });
        });
    </script>
}