@model IEnumerable<WatchStoreApp.Models.Product>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Products";
    // Define theme color for borders, buttons, and icon hovers
    var themeGreen = "#005844";
}

<div class="w-full p-8 bg-white font-sans min-h-screen">

    <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
        <h1 class="text-2xl font-bold text-gray-800 uppercase tracking-wide">PRODUCTS</h1>

        <div class="flex items-center gap-4 w-full md:w-auto relative">
            <form asp-action="Search" method="post" class="relative flex-grow md:flex-grow-0 md:w-[400px]">
                <input type="text" name="search_product" placeholder="Enter product name ..."
                       class="w-full pl-4 pr-10 py-2.5 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-[color:var(--theme)]" style="--theme:@themeGreen" />
                <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                    <i class="bi bi-search text-lg"></i>
                </button>
            </form>

            <div class="relative">
                <button id="createDropdownBtn"
                        class="px-8 py-2.5 bg-[color:var(--theme)] text-white font-medium rounded-md hover:opacity-90 transition shadow-sm uppercase flex items-center gap-2" style="--theme:@themeGreen">
                    Create <i class="bi bi-chevron-down"></i>
                </button>
                <div id="createDropdownMenu" class="absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg py-1 z-10 hidden border border-gray-200">
                    <a href="/Product/CreateMechanical" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 hover:text-[color:var(--theme)] transition" style="--theme:@themeGreen">
                        Mechanical Watch
                    </a>
                    <a href="/Product/CreateSmartwatch" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 hover:text-[color:var(--theme)] transition" style="--theme:@themeGreen">
                        Smartwatch
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)]" style="--theme:@themeGreen">ID</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)]" style="--theme:@themeGreen">Product</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)] text-center" style="--theme:@themeGreen">Quantity</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)] text-right" style="--theme:@themeGreen">Import Price</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)] text-right" style="--theme:@themeGreen">Retail Price</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)] text-right" style="--theme:@themeGreen"></th>
                </tr>
            </thead>
            <tbody class="text-gray-700">
                @foreach (var product in Model)
                {
                    // Logic Preserved: Disabled state check
                    var isDisabled = product.Flag == 0;

                    // Styling classes: Zebra striping and hover effect
                    var baseRowClass = "border-b border-gray-100 align-middle transition hover:bg-gray-50";
                    var stripeClass = "even:bg-gray-100";
                    var disabledClass = isDisabled ? "opacity-50 pointer-events-none bg-gray-50" : "";

                    <tr class="@baseRowClass @stripeClass @disabledClass">
                        <td class="py-6 px-6 text-lg font-medium">@product.ProductId</td>

                        <td class="py-6 px-6">
                            <div class="flex items-center gap-4">
                                <img src="@product.ImageUrl1" alt="@product.Name" class="w-20 h-20 object-cover rounded-md border border-gray-200" />
                                <div>
                                    <p class="text-lg font-semibold text-gray-900 line-clamp-2" title="@product.Name">@product.Name</p>
                                    <p class="text-sm text-gray-500">@product.WatchType</p>
                                </div>
                            </div>
                        </td>

                        <td class="py-6 px-6 text-lg text-center">@product.StockQuantity</td>

                        <td class="py-6 px-6 text-lg text-right font-medium">@product.ImportPrice.ToString("N0") ₫</td>

                        <td class="py-6 px-6 text-lg text-right font-medium text-[color:var(--theme)]" style="--theme:@themeGreen">@product.SellingPrice.ToString("N0") ₫</td>

                        <td class="py-6 px-6 text-right whitespace-nowrap">
                            <div class="flex justify-end items-center gap-6 text-xl">
                                @if (!isDisabled)
                                {
                                    // Edit Icon (Logic Preserved: Conditional onclick navigation based on WatchType)
                                    var editUrl = product.WatchType == "Smartwatch"
                                    ? $"/Product/EditSmartwatch?id={product.ProductId}"
                                    : $"/Product/EditMechanical?id={product.ProductId}";

                                    <button type="button" class="text-gray-500 hover:text-[color:var(--theme)] transition" style="--theme:@themeGreen" title="Edit"
                                            onclick="window.location.href='@editUrl'">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    // Delete Icon (Logic Preserved: onclick navigation)
                                    <button type="button" class="text-gray-500 hover:text-red-600 transition" title="Delete"
                                            onclick="window.location.href='/Product/Delete?id=@product.ProductId'">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                }
                                else
                                {
                                    // Disabled Icons
                                    <span class="text-gray-300 cursor-not-allowed"><i class="bi bi-pencil-square"></i></span>
                                    <span class="text-gray-300 cursor-not-allowed"><i class="bi bi-trash3"></i></span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    const dropdownBtn = document.getElementById('createDropdownBtn');
    const dropdownMenu = document.getElementById('createDropdownMenu');

    if (dropdownBtn && dropdownMenu) {
        dropdownBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            dropdownMenu.classList.toggle('hidden');
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', (e) => {
            if (!dropdownBtn.contains(e.target) && !dropdownMenu.contains(e.target)) {
                dropdownMenu.classList.add('hidden');
            }
        });
    }
</script>