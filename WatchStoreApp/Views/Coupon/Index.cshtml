@model IEnumerable<WatchStoreApp.Models.Coupon>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Coupons";
    // Define theme color for buttons/borders
    var themeDarkGreen = "#004d40";
}

<div class="w-full p-8 bg-white font-sans">

    <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
        <h1 class="text-2xl font-bold text-gray-800 uppercase tracking-wide">COUPONS</h1>

        <div class="flex items-center gap-4 w-full md:w-auto">
            <form asp-action="Search" method="post" class="relative flex-grow md:flex-grow-0 md:w-96">
                <input type="text" name="search_coupon" placeholder="Enter coupon code ..."
                       class="w-full pl-4 pr-10 py-2.5 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-[color:var(--theme)]" style="--theme:@themeDarkGreen" />
                <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                    <i class="bi bi-search text-lg"></i>
                </button>
            </form>

            <button name="btn_create"
                    class="px-8 py-2.5 bg-[color:var(--theme)] text-white font-medium rounded-md hover:opacity-90 transition shadow-sm uppercase" style="--theme:@themeDarkGreen">
                Create
            </button>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)]" style="--theme:@themeDarkGreen">ID</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)]" style="--theme:@themeDarkGreen">Coupon Code</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)]" style="--theme:@themeDarkGreen">Start Date</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)]" style="--theme:@themeDarkGreen">Expire Date</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)] text-right" style="--theme:@themeDarkGreen"></th>
                </tr>
            </thead>
            <tbody class="text-gray-700">
                @foreach (var coupon in Model)
                {
                    // Logic Preserved: Disabled state check
                    var isDisabled = coupon.Flag == 0;

                    // Styling classes
                    var baseRowClass = "border-b border-gray-100 align-middle transition hover:bg-gray-50";
                    var stripeClass = "even:bg-gray-100"; // Zebra striping
                    var disabledClass = isDisabled ? "opacity-50 pointer-events-none bg-gray-50" : "";

                    <tr class="@baseRowClass @stripeClass @disabledClass">
                        <td class="py-6 px-6 text-lg font-medium">@coupon.CouponId</td>

                        <td class="py-6 px-6 text-lg">@coupon.CouponCode</td>

                        <td class="py-6 px-6 text-lg">@coupon.StartDate.ToString("dd/MM/yyyy")</td>

                        <td class="py-6 px-6 text-lg">@coupon.ExpireDate.ToString("dd/MM/yyyy")</td>

                        <td class="py-6 px-6 text-right whitespace-nowrap">
                            <div class="flex justify-end items-center gap-4 text-xl">
                                @if (!isDisabled)
                                {
                                    // Edit Icon (Logic Preserved: onclick navigation)
                                    <button type="button" class="text-gray-600 hover:text-blue-600 transition" title="Edit"
                                            onclick="window.location.href='/Coupon/Edit?id=@coupon.CouponId'">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    // Delete Icon (Logic Preserved: onclick navigation)
                                    <button type="button" class="text-gray-600 hover:text-red-600 transition" title="Delete"
                                            onclick="window.location.href='/Coupon/Delete?id=@coupon.CouponId'">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                }
                                else
                                {
                                    // Disabled Icons
                                    <span class="text-gray-300 cursor-not-allowed"><i class="bi bi-pencil-square"></i></span>
                                    <span class="text-gray-300 cursor-not-allowed"><i class="bi bi-trash3"></i></span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    document.getElementsByName("btn_create")[0].onclick = function () {
        window.location.href = "/Coupon/Create";
    };
</script>