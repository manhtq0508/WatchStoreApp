@{
    ViewData["Title"] = "Reset Password";
    var backgroundImage = Url.Content("~/images/banner/banner0.png");
}

<div class="min-h-screen bg-cover bg-center flex items-center justify-end px-6"
     style="background-image: linear-gradient(90deg, rgba(0,0,0,0.25), rgba(0,0,0,0.45)), url('@backgroundImage'); padding-top: 60px; padding-bottom: 60px;">

    <div class="w-1/2 max-w-lg bg-white rounded-3xl shadow-2xl text-gray-900"
         style="padding: 48px 56px; margin-right: 40px;">

        <h2 class="text-3xl font-bold mb-8 text-center" style="color: #000000;">Reset Password</h2>

        <form method="post" asp-action="ResetPassword" class="space-y-6">
            @Html.AntiForgeryToken()

            <input type="hidden" name="email" value="@ViewBag.Email" />

            <div class="relative">
                <input type="password" name="newPassword" id="newPassword" required
                       placeholder="New Password"
                       class="w-full px-4 py-3 pr-12 bg-white border border-gray-300 rounded-md
                              focus:outline-none focus:ring-2 focus:ring-[#015D4E]" />
                <button type="button" onclick="togglePassword('newPassword')"
                        class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-600 hover:text-gray-800 focus:outline-none">
                    <i class="fa fa-eye" id="newPassword-eye"></i>
                </button>
            </div>

            <div class="relative">
                <input type="password" name="confirmPassword" id="confirmPassword" required
                       placeholder="Confirm Password"
                       class="w-full px-4 py-3 pr-12 bg-white border border-gray-300 rounded-md
                              focus:outline-none focus:ring-2 focus:ring-[#015D4E]" />
                <button type="button" onclick="togglePassword('confirmPassword')"
                        class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-600 hover:text-gray-800 focus:outline-none">
                    <i class="fa fa-eye" id="confirmPassword-eye"></i>
                </button>
            </div>

            <button type="submit"
                    class="w-full bg-[#015D4E] text-white py-3 rounded-2xl font-semibold hover:opacity-90 transition"
                    style="background-color: #015D4E; color: #FFFFFF; border-radius: 2px; margin-top: 30px;">
                Reset Password
            </button>

            <div class="flex flex-col gap-3 mt-6">
                <p class="text-sm text-center text-black">
                    <a href="/Signin" class="hover:underline" style="color: #015D4E;">
                        &larr; Back to main page
                    </a>
                </p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="bg-red-50 border border-red-200 rounded-md p-4 mt-4">
                    <p class="text-red-600 text-sm">@ViewBag.Error</p>
                </div>
            }

            @if (ViewBag.Success != null)
            {
                <div class="bg-green-50 border border-green-200 rounded-md p-4 mt-4">
                    <p class="text-green-600 text-sm">@ViewBag.Success</p>
                </div>
            }
        </form>
    </div>
</div>

<script>
    function togglePassword(fieldId) {
        const field = document.getElementById(fieldId);
        const eyeIcon = document.getElementById(fieldId + '-eye');

        if (field.type === 'password') {
            field.type = 'text';
            eyeIcon.classList.remove('fa-eye');
            eyeIcon.classList.add('fa-eye-slash');
        } else {
            field.type = 'password';
            eyeIcon.classList.remove('fa-eye-slash');
            eyeIcon.classList.add('fa-eye');
        }
    }
</script>