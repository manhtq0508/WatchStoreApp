@{
    ViewData["Title"] = "Forgot Password";
    var backgroundImage = Url.Content("~/images/banner/banner0.png");
}

<div class="min-h-screen bg-cover bg-center flex items-center justify-end px-6"
     style="background-image: linear-gradient(90deg, rgba(0,0,0,0.25), rgba(0,0,0,0.45)), url('@backgroundImage'); padding-top: 60px; padding-bottom: 60px;">

    @* REVERTED: Your original box structure *@
    <div class="w-1/2 max-w-lg bg-white rounded-3xl shadow-2xl text-gray-900"
         style="padding: 48px 56px; margin-right: 40px;">

        @* UPDATED: Text matches the image (Sentence case) *@
        <h2 class="text-3xl font-bold mb-4 text-center" style="color: #000000;">Forgot password</h2>

        @* UPDATED: Subtext matches the image *@
        <p class="text-sm text-gray-600 text-center mb-8">
            Please enter your registered email address.<br>
            We'll send you a link to reset your password.
        </p>

        <form method="post" asp-action="ForgotPassword" class="space-y-6">
            @Html.AntiForgeryToken()

            <div>
                <input type="email" name="email" required
                       placeholder="Email"
                       class="w-full px-4 py-3 bg-white border border-gray-300 rounded-md
                              focus:outline-none focus:ring-2 focus:ring-[#015D4E]" />
            </div>

            <button type="submit"
                    class="w-full bg-[#015D4E] text-white py-3 rounded-2xl font-semibold hover:opacity-90 transition"
                    style="background-color: #015D4E; color: #FFFFFF; border-radius: 2px; margin-top: 30px;">
                Send reset link
            </button>

            @* UPDATED: Single "Back to main page" link matching the image *@
            <div class="flex flex-col gap-3 mt-6">
                <p class="text-sm text-center text-black">
                    <a href="/Signin" class="hover:underline" style="color: #015D4E;">
                        &larr; Back to main page
                    </a>
                </p>
            </div>

            @* LOGIC PRESERVED *@
            @if (ViewBag.Error != null || TempData["Error"] != null)
            {
                <div class="bg-red-50 border border-red-200 rounded-md p-4 mt-4">
                    <p class="text-red-600 text-sm">@(ViewBag.Error ?? TempData["Error"])</p>
                </div>
            }

            @if (ViewBag.Success != null || TempData["Success"] != null)
            {
                <div class="bg-green-50 border border-green-200 rounded-md p-4 mt-4">
                    <p class="text-green-600 text-sm">@(ViewBag.Success ?? TempData["Success"])</p>
                    @if (ViewBag.ShowResetForm == true)
                    {
                        <div class="mt-4">
                            <a href="/Register/ResetPassword?email=@ViewBag.Email"
                               class="block w-full text-center px-4 py-2 bg-[#015D4E] text-white rounded-md font-medium hover:opacity-90 transition">
                                Reset Password Now
                            </a>
                        </div>
                    }
                </div>
            }
        </form>
    </div>
</div>