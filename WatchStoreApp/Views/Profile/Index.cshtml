@model WatchStoreApp.ViewModel.Profile.UpdateProfileVM
@{
    ViewData["Title"] = "My Profile";
}

<div class="min-h-screen bg-gray-100 py-10 px-4">
    <div class="max-w-4xl mx-auto">

        <!-- Header -->
        <div class="flex items-center gap-4 mb-8">
            <div class="w-16 h-16 rounded-full bg-green-600 flex items-center justify-center text-white text-3xl shadow">
                <i class="bi bi-person"></i>
            </div>
            <div>
                <h2 class="text-3xl font-bold text-gray-800">My Profile</h2>
                <p class="text-gray-500">Manage your personal information</p>
            </div>
        </div>

        <!-- Card -->
        <div class="bg-white rounded-2xl shadow-xl p-8">
            <form method="post" class="space-y-8">
                <input type="hidden" asp-for="CustomerId" />

                <!-- Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                    <!-- Full Name -->
                    <div>
                        <label asp-for="Name" class="block text-sm font-semibold text-gray-700 mb-2">
                            Full Name
                        </label>
                        <input asp-for="Name"
                               placeholder="Enter your full name"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition" />
                        <span asp-validation-for="Name" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Date of Birth -->
                    <div>
                        <label asp-for="DateOfBirth" class="block text-sm font-semibold text-gray-700 mb-2">
                            Date of Birth
                        </label>
                        <input asp-for="DateOfBirth" type="date"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition" />
                        <span asp-validation-for="DateOfBirth" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Gender -->
                    <div>
                        <label asp-for="Gender" class="block text-sm font-semibold text-gray-700 mb-2">
                            Gender
                        </label>
                        <select asp-for="Gender" asp-items="ViewBag.Gender"
                                class="w-full px-4 py-3 border border-gray-300 rounded-lg bg-white focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition">
                        </select>
                        <span asp-validation-for="Gender" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Phone -->
                    <div>
                        <label asp-for="PhoneNumber" class="block text-sm font-semibold text-gray-700 mb-2">
                            Phone Number
                        </label>
                        <input asp-for="PhoneNumber"
                               placeholder="Enter phone number"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition" />
                        <span asp-validation-for="PhoneNumber" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Email -->
                    <div class="md:col-span-2">
                        <label asp-for="Email" class="block text-sm font-semibold text-gray-700 mb-2">
                            Email
                        </label>
                        <input asp-for="Email" readonly
                               class="w-full px-4 py-3 border border-gray-200 rounded-lg bg-gray-100 text-gray-500 cursor-not-allowed" />
                        <p class="text-xs text-gray-400 mt-1">Email cannot be changed</p>
                    </div>

                    <!-- Password -->
                    <div class="md:col-span-2">
                        <label asp-for="Password" class="block text-sm font-semibold text-gray-700 mb-2">
                            Password
                        </label>
                        <input asp-for="Password" type="password"
                               placeholder="Enter new password"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition" />
                        <span asp-validation-for="Password" class="text-red-500 text-sm"></span>
                    </div>
                </div>

                <!-- Buttons -->
                <div class="flex justify-between items-center pt-6 border-t">
                    <a href="/Home"
                       class="px-6 py-3 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-100 transition font-medium flex items-center gap-2">
                        <i class="bi bi-arrow-left"></i> Back
                    </a>

                    <button type="submit"
                            class="px-8 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 transition font-semibold flex items-center gap-2 shadow">
                        <i class="bi bi-check-circle"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
