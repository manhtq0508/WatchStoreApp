@model IEnumerable<WatchStoreApp.Models.Brand>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Brand Details";
    // Define the theme color for buttons/borders based on the image
    var themeDarkGreen = "#004d40"; // A dark teal/green shade
}

<div class="w-full bg-white p-8">

    <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
        <h1 class="text-2xl font-bold text-gray-800 uppercase tracking-wide">BRANDS</h1>

        <div class="flex items-center gap-4 w-full md:w-auto">
            <form asp-action="Search" method="post" class="relative flex-grow md:flex-grow-0 md:w-96">
                <input type="text" name="search_brand" placeholder="Enter brand name ..."
                       class="w-full pl-4 pr-10 py-2.5 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-[color:var(--theme)]" style="--theme:@themeDarkGreen" />
                <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                    <i class="bi bi-search text-lg"></i>
                </button>
            </form>

            <button name="btn_create"
                    class="px-6 py-2.5 bg-[color:var(--theme)] text-white font-medium rounded-md hover:opacity-90 transition shadow-sm" style="--theme:@themeDarkGreen">
                Create
            </button>
        </div>
    </div>


    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)]" style="--theme:@themeDarkGreen">ID</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)] text-center" style="--theme:@themeDarkGreen">Image</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)]" style="--theme:@themeDarkGreen">Brand Name</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)]" style="--theme:@themeDarkGreen">Origin</th>
                    <th class="py-4 px-6 text-lg font-bold text-gray-800 border-b-2 border-[color:var(--theme)] text-right" style="--theme:@themeDarkGreen"></th>
                </tr>
            </thead>
            <tbody class="text-gray-700">
                @foreach (var brand in Model)
                {
                    var isDisabled = brand.Flag == 0;
                    // Base class for styling
                    var baseRowClass = "border-b border-gray-100 align-middle transition hover:bg-gray-50";
                    // Zebra striping using Tailwind's even: modifier
                    var stripeClass = "even:bg-gray-100";
                    // Disabled state logic (preserved from original)
                    var disabledClass = isDisabled ? "opacity-50 pointer-events-none bg-gray-50" : "";

                    <tr class="@baseRowClass @stripeClass @disabledClass">
                        <td class="py-6 px-6 text-lg font-medium">@brand.BrandId</td>

                        <td class="py-6 px-6 text-center">
                            <img src="@brand.ImageUrl" alt="@brand.BrandName" class="h-16 w-auto mx-auto object-contain" />
                        </td>

                        <td class="py-6 px-6 text-lg">@brand.BrandName</td>

                        <td class="py-6 px-6 text-lg">@brand.Origin</td>

                        <td class="py-6 px-6 text-right whitespace-nowrap">
                            <div class="flex justify-end items-center gap-4 text-xl">
                                @if (!isDisabled)
                                {
                                    // Edit Icon
                                    <button type="button" class="text-gray-600 hover:text-blue-600 transition" title="Edit"
                                            onclick="window.location.href='/Brand/Edit?id=@brand.BrandId'">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    // Delete Icon
                                    <button type="button" class="text-gray-600 hover:text-red-600 transition" title="Delete"
                                            onclick="window.location.href='/Brand/Delete?id=@brand.BrandId'">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                }
                                else
                                {
                                    // Disabled Icons
                                    <span class="text-gray-300 cursor-not-allowed"><i class="bi bi-pencil-square"></i></span>
                                    <span class="text-gray-300 cursor-not-allowed"><i class="bi bi-trash3"></i></span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* Keep the existing script for the create button redirect *@
<script>
    document.getElementsByName("btn_create")[0].onclick = function () {
        window.location.href = "/Brand/Create";
    };
</script>